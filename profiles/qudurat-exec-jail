# qudurat-exec-jail — AppArmor execution restriction profile
# Generated by apparmor_manager.py — may be overwritten on jail start.
# Confines bash and zsh so they can only exec Firefox.

profile qudurat-exec-jail /usr/bin/{ba,z}sh {
  # Shell self-read
  /usr/bin/{ba,z}sh mr,

  # Dynamic linker and system libraries
  /etc/ld.so.cache r,
  /usr/lib/** mr,
  /usr/lib64/** mr,

  # Minimal /proc reads the shell needs for its own operation
  /proc/*/status r,
  /proc/*/fd/ r,
  /proc/meminfo r,

  # Firefox binary and all helpers / resources under /usr/lib/firefox/
  /usr/bin/firefox ix,
  /usr/lib/firefox/ r,
  /usr/lib/firefox/** ix,

  # Deny execution of all other binaries
  deny /usr/bin/* x,
  deny /usr/local/bin/* x,
  deny /bin/* x,
  deny /sbin/* x,
  deny /usr/sbin/* x,
  deny /usr/local/sbin/* x,
  deny /opt/** x,
  deny /snap/** x,
  deny /home/** x,
  deny /root/** x,
  deny /tmp/** x,
}
