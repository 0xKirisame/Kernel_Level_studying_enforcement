{# nftables.j2 — Jinja2 template for qudurat_jail ruleset.
   Variables:
     allowed_ips  : list[str]   — resolved IPv4 addresses
     allow_ports  : list[int]   — TCP ports to allow (default: [80, 443])
#}
table inet qudurat_jail {
  set allowed_ips {
    type ipv4_addr
    flags interval
    {% if allowed_ips %}
    elements = { {{ allowed_ips | join(', ') }} }
    {% endif %}
  }

  chain output {
    type filter hook output priority 0; policy drop;

    # Loopback
    oif lo accept

    # Established / related
    ct state established,related accept

    # DNS only to localhost — blocks Firefox DoH and external resolvers
    udp dport 53 ip daddr != 127.0.0.1 drop
    tcp dport 53 ip daddr != 127.0.0.1 drop

    # HTTP/HTTPS to whitelisted IPs only
    tcp dport { {{ allow_ports | join(', ') }} } ip daddr @allowed_ips accept

    # Everything else falls through to policy drop
  }
}
